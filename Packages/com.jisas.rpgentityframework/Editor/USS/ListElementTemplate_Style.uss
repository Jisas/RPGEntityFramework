:root {
}

.template-base {
    flex-grow: 1;
    flex-direction: row;
}

.template-icon {
    flex-grow: initial;
    width: 35px;
    height: 35px;
}

.template-name {
    -unity-font-definition: resource("Fonts/Montserrat-Light");
    font-size: 15px;
    -unity-text-align: middle-left;
    color: rgb(255, 255, 255);
    margin-left: 0;
    margin-top: 0;
    margin-right: 0;
    margin-bottom: 0;
    padding-top: 0;
    padding-right: 0;
    padding-bottom: 0;
    padding-left: 0;
}
